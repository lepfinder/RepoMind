{
  "manifest_version": 3,
  "name": "github-index",
  "version": "1.0.0",
  "description": "一键将 GitHub 项目导入到本地 github-index",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:3001/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
